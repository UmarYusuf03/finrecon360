BREVO_API_KEY="<your_brevo_api_key>"
BREVO_SENDER_EMAIL="sender@example.com"
BREVO_SENDER_NAME="finrecon360"
BREVO_TEMPLATE_ID_MAGICLINK_VERIFY=2
BREVO_TEMPLATE_ID_MAGICLINK_RESET=1
BREVO_TEMPLATE_ID_MAGICLINK_CHANGE=3
MAGICLINK_EXPIRES_MINUTES=10
MAGICLINK_MAX_ATTEMPTS=5
MAGICLINK_RESEND_COOLDOWN_SECONDS=60
FRONTEND_BASE_URL="http://localhost:4200"
ADMIN_EMAILS="admin@yourdomain.com"
SYSTEM_ADMIN_EMAIL="admin@yourdomain.com"
SYSTEM_ADMIN_PASSWORD="<strong_password>"
SYSTEM_ADMIN_FIRST_NAME="System"
SYSTEM_ADMIN_LAST_NAME="Admin"
TENANT_DB_TEMPLATE="Server=YOUR_SERVER;Database=FinRecon360_Tenant_{tenantId};Trusted_Connection=True;TrustServerCertificate=True;"

STRIPE_API_KEY="<stripe_api_key>"
STRIPE_WEBHOOK_SECRET="<stripe_webhook_secret>"
STRIPE_SUCCESS_URL="http://localhost:4200/onboarding/success"
STRIPE_CANCEL_URL="http://localhost:4200/onboarding/cancel"

ONBOARDING_TOKEN_ISSUER="finrecon360"
ONBOARDING_TOKEN_AUDIENCE="onboarding"
ONBOARDING_TOKEN_EXPIRES_MINUTES=20

# .NET configuration via env vars
ConnectionStrings__DefaultConnection="Server=YOUR_SERVER;Database=FinRecon360;Trusted_Connection=True;TrustServerCertificate=True;"
Jwt__Key="<long_random_secret>"
Jwt__Issuer="finrecon360_backend"
Jwt__Audience="finrecon360_backend.Client"
Jwt__ExpiresMinutes=60
