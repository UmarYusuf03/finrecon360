BREVO_API_KEY="your_brevo_api_key"
BREVO_SENDER_EMAIL="noreply@example.com"
BREVO_SENDER_NAME="finrecon360"
BREVO_TEMPLATE_ID_MAGICLINK_VERIFY=2
BREVO_TEMPLATE_ID_MAGICLINK_INVITE=2
BREVO_TEMPLATE_ID_MAGICLINK_RESET=2
BREVO_TEMPLATE_ID_MAGICLINK_CHANGE=2
MAGICLINK_EXPIRES_MINUTES=10
MAGICLINK_MAX_ATTEMPTS=5
MAGICLINK_RESEND_COOLDOWN_SECONDS=60
RATE_LIMIT_ADMIN_PER_MINUTE=120
FRONTEND_BASE_URL="http://localhost:4200"
SYSTEM_ADMIN_EMAIL="admin@yourdomain.com"
SYSTEM_ADMIN_PASSWORD="replace_with_strong_password"
SYSTEM_ADMIN_FIRST_NAME="System"
SYSTEM_ADMIN_LAST_NAME="Admin"

# Temporary local bypass for onboarding/payment (set true only in local dev)
TEMP_BYPASS_SEED_TENANT_ADMIN=false
# Tenant bootstrap profile (used only when TEMP_BYPASS_SEED_TENANT_ADMIN=true)
TEMP_BYPASS_TENANT_NAME="demo-tenant-name"
TEMP_BYPASS_TENANT_ADMIN_EMAIL="tenant-admin@example.com"
TEMP_BYPASS_TENANT_ADMIN_PASSWORD="replace_with_strong_password"
TEMP_BYPASS_TENANT_ADMIN_FIRST_NAME="Tenant"
TEMP_BYPASS_TENANT_ADMIN_LAST_NAME="Admin"
TENANT_DB_TEMPLATE="Server=localhost,1433;Database=FinRecon360_Tenant_{tenantId};User Id=sa;Password=your_sql_password;TrustServerCertificate=True;"

STRIPE_API_KEY="stripe_api_key"
STRIPE_WEBHOOK_SECRET="stripe_webhook_secret"
STRIPE_SUCCESS_URL="http://localhost:4200/onboarding/success"
STRIPE_CANCEL_URL="http://localhost:4200/onboarding/cancel"

ONBOARDING_TOKEN_ISSUER="finrecon360"
ONBOARDING_TOKEN_AUDIENCE="onboarding"
ONBOARDING_TOKEN_EXPIRES_MINUTES=20

# .NET configuration via env vars
ConnectionStrings__DefaultConnection="Server=localhost,1433;Database=FinRecon360;User Id=sa;Password=your_sql_password;TrustServerCertificate=True;"
Jwt__Key="replace_with_a_strong_key"
Jwt__Issuer="finrecon360_backend"
Jwt__Audience="finrecon360_backend.Client"
Jwt__ExpiresMinutes=60
